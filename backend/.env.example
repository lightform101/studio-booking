# =============================================
# Studio Space 預約系統 - 環境變數設定範本
# 複製此檔案為 .env 並填入實際值
# =============================================

# 伺服器設定
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# 資料庫 (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=studio_booking
DB_USER=root
DB_PASS=your_mysql_password
DB_POOL_MAX=10
DB_POOL_MIN=0

# JWT 認證
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# =============================================
# 藍新金流 NewebPay
# 申請網址: https://www.newebpay.com
# =============================================
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
# sandbox | production
NEWEBPAY_ENV=sandbox

# =============================================
# LINE Pay
# 申請網址: https://pay.line.me/tw/developers/techsupport/sandbox/create
# =============================================
LINEPAY_CHANNEL_ID=
LINEPAY_CHANNEL_SECRET=
# sandbox | production
LINEPAY_ENV=sandbox

# =============================================
# 電子發票 (綠界 ECPay)
# 申請網址: https://vendor.ecpay.com.tw
# =============================================
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
# sandbox | production
ECPAY_ENV=sandbox

# =============================================
# Email 設定 (SMTP)
# Gmail 請使用「應用程式密碼」，非登入密碼
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM_NAME=Studio Space
EMAIL_FROM=noreply@studiospace.tw

# =============================================
# 簡訊設定 (每日簡訊 mitake)
# 申請網址: https://sms.mitake.com.tw
# =============================================
SMS_PROVIDER=mitake
MITAKE_USERNAME=
MITAKE_PASSWORD=
SMS_SENDER=StudioSP

# =============================================
# 系統設定
# =============================================
# 付款等待時間（分鐘）
BOOKING_LOCK_MINUTES=120
# 最少提前預約時數
MIN_ADVANCE_HOURS=24
# 後台管理員預設帳密 (首次執行 seed 時建立)
ADMIN_EMAIL=admin@studiospace.tw
ADMIN_PASSWORD=Admin@1234
